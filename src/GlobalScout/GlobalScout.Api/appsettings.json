{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Jwt": {
    "Issuer": "GlobalScout",
    "Audience": "GlobalScout",
    "SigningKey": "OverrideInProduction_UseAtLeast32Characters!!",
    "AccessTokenExpirationDays": 7
  },
  "ObjectStorage": {
    "Provider": "S3",
    "BucketName": "globalscout-media",
    "Region": "us-east-1",
    "EndpointUrl": "",
