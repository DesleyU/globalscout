    "SecretKey": "",
    "ForcePathStyle": false,
    "UploadUrlMinutes": 15,
    "ReadUrlMinutes": 10,
    "CreateBucketIfMissing": false
  },
  "ApiFootball": {
    "ApiKey": "",
    "Host": "v3.football.api-sports.io",
    "BaseUrl": "https://v3.football.api-sports.io"
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": "",
    "PublishableKey": "",
    "PremiumPriceId": "",
    "PublicAppBaseUrl": "http://localhost:5173",
    "CheckoutSuccessPath": "/payment/success",
    "CheckoutCancelPath": "/payment/cancel",
    "BillingPortalReturnPath": "/profile"
  }
}
