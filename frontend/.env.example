# Frontend Environment Variables

# API Configuration
# When using GlobalScout.AppHost (Aspire), VITE_API_URL is set automatically to the API HTTP endpoint + /api — you do not need a .env file for that flow.
# Leave unset (or use "/api") for standalone Vite dev with vite.config.js proxy to the .NET API.
# For direct calls to the API (e.g. debugging without Aspire), use the HTTP URL from GlobalScout.Api launchSettings (e.g. http://localhost:5288/api).
# Production: set to your deployed API base, e.g. https://api.yourdomain.com/api — and configure Cors:AllowedOrigins on the API for your SPA origin.
# VITE_API_URL=http://localhost:5288/api



# PayPal Configuration
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# App Configuration
VITE_APP_NAME=GlobalScout
VITE_APP_VERSION=1.0.0