# Frontend Environment Variables

# API Configuration
# When using GlobalScout.AppHost (Aspire), VITE_API_BASE_URL is set automatically to the API HTTPS endpoint + /api.
# For standalone Vite or Docker dev, this should point at the .NET API host from launchSettings/docker-compose.
# Production: https://api.globalscout.eu/api
VITE_API_BASE_URL=http://localhost:5288/api



# PayPal Configuration
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# App Configuration
VITE_APP_NAME=GlobalScout
VITE_APP_VERSION=1.0.0