# Copy this file to /opt/globalscout/.env on the EC2 host and replace every secret.

POSTGRES_DB=globalscout
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password

Jwt__Issuer=GlobalScout
Jwt__Audience=GlobalScout
Jwt__SigningKey=replace-with-at-least-32-random-characters

AdminSeed__Email=
AdminSeed__Password=

Stripe__SecretKey=
Stripe__WebhookSecret=
Stripe__PublishableKey=
Stripe__PremiumPriceId=
Stripe__PublicAppBaseUrl=https://globalscout.eu

ApiFootball__ApiKey=
ApiFootball__Host=v3.football.api-sports.io
ApiFootball__BaseUrl=https://v3.football.api-sports.io

ObjectStorage__Provider=S3
ObjectStorage__BucketName=globalscout-prod-media
ObjectStorage__Region=eu-central-1
ObjectStorage__ForcePathStyle=false
ObjectStorage__CreateBucketIfMissing=false

HTTP_PORT=80
